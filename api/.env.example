# API - Variables d'environnement (copier vers .env pour le dev local)

# Avec Docker : docker compose up -d db  puis :
DATABASE_URL=postgresql://app:app@localhost:5432/app
BETTER_AUTH_SECRET=generate-a-32-char-secret
BETTER_AUTH_URL=http://localhost:3001
# Front local ; * = autorise aussi les clients sans Origin (ex. Postman)
TRUSTED_ORIGINS=http://localhost:3000
PORT=3001
AWS_REGION=eu-west-3
# Bucket unique pour assets et backups (sous-dossiers assets/ et backups/)
# Aligné sur deploy-assets : dev / prd séparés ; en local souvent le bucket dev
S3_ASSETS_BUCKET=cloud-serverless-iimb3-assets-dev
S3_BACKUP_BUCKET=your-assets-bucket

# OAuth social providers (optionnel — les boutons s'affichent côté front même sans ces variables)
# Google : une seule app pour local + dev + prod (plusieurs redirect URIs)
# GitHub : une app par env (local, dev, prd) car une seule callback URL par app
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Prod (Lambda) - TRUSTED_ORIGINS à configurer dans la console AWS
# TRUSTED_ORIGINS=https://EOEAWOPA70Y94.cloudfront.net,https://E1BU4QTS6O9GKH.cloudfront.net
