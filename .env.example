# Copier vers .env et remplir les valeurs
# Utilisé par scripts/deploy.py pour le déploiement local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3

# Bucket unique pour assets et backups (sous-dossiers assets/ et backups/)
S3_ASSETS_BUCKET=
S3_BACKUP_BUCKET=
S3_BUCKET_USER_DEV=
S3_BUCKET_USER_PRD=
S3_BUCKET_ADMIN_DEV=
S3_BUCKET_ADMIN_PRD=

CF_ID_USER_DEV=
CF_ID_USER_PRD=
CF_ID_ADMIN_DEV=
CF_ID_ADMIN_PRD=

# Lambda (pour deploy-api.py)
LAMBDA_FUNCTION_DEV=
LAMBDA_FUNCTION_PRD=
LAMBDA_FUNCTION_CRON=cloud-serverless-iimb3-cron

# Base de données RDS (pour API Lambda)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Bases de données pour la Lambda cron (backup des 2 databases)
DATABASE_URL_DEV=postgresql://user:password@host:5432/postgres
DATABASE_URL_PRD=postgresql://user:password@host:5432/postgres_prd

# Frontend (build Next.js) - pour déploiement
NEXT_PUBLIC_API_URL=https://xxx.lambda-url.eu-west-3.on.aws
# URL du site user (pour redirection login depuis admin, évite la boucle de reload)
NEXT_PUBLIC_USER_SITE_URL=https://xxx.cloudfront.net

# API Lambda - TRUSTED_ORIGINS (prod) : URLs CloudFront front user + admin
# Format: https://{CF_ID_USER_PRD}.cloudfront.net,https://{CF_ID_ADMIN_PRD}.cloudfront.net
TRUSTED_ORIGINS_PRD=https://EOEAWOPA70Y94.cloudfront.net,https://E1BU4QTS6O9GKH.cloudfront.net

# OAuth social providers (passées au service api via docker-compose)
# Google : une app pour tout. GitHub : OAUTH_GITHUB_*_DEV et _PRD pour CI
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# SES — adresse expéditrice vérifiée dans AWS SES
# En sandbox : FROM et TO doivent être des adresses vérifiées
SES_FROM_EMAIL=nathan.boisleux@edu.devinci.fr

# URL du site user (utilisée pour le lien dans les emails d'invitation)
USER_SITE_URL=https://xxx.cloudfront.net
